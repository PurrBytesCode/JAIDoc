# =============================================================================
# JAIDoc MCP Server — HTTP Client (IntelliJ compatible)
# =============================================================================
# Tests the Spring AI MCP Server (streamable HTTP protocol) exposed on /mcp.
#
# Prerequisites:
#   1. Start the application (Spring Boot entry point: com.purrbyte.ai.JAIDoc).
#   2. The MCP server will be available at http://localhost:8080/mcp by default.
#      Override the server port via SPRING_AI_MCP_SERVER_BASE_URL or server.port.
#
# Usage in IntelliJ:
#   - Open this file. IntelliJ recognizes the .http extension and provides
#     a "Run" (green arrow) button next to each request.
#   - You can also select a request and press Ctrl+Alt+Shift+Enter.
# =============================================================================

### Initialize MCP Session
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-11-25",
    "capabilities": {},
    "clientInfo": {
      "name": "IntelliJ HTTP Client",
      "version": "1.0.0"
    }
  }
}

> {%
    client.global.set("mcpSessionId", response.headers.valueOf("Mcp-Session-Id"));
    client.log("MCP Session ID: " + client.global.get("mcpSessionId"));
%}

### List Tools — verify registered MCP tools
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 2,
  "method": "tools/list",
  "params": {
    "cursor": null
  }
}

### List JDK Versions
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "listVersions",
    "arguments": {}
  }
}

### Search JDK Javadoc — semantic search
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "searchJavadoc",
    "arguments": {
      "version": "25.0.3",
      "query": "how to create a new thread",
      "topK": 5
    }
  }
}

### Search for String API
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "searchJavadoc",
    "arguments": {
      "version": "25.0.3",
      "query": "String substring method",
      "topK": 3
    }
  }
}

### Start Doc Generation — async task
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 5,
  "method": "tools/call",
  "params": {
    "name": "startDocGeneration",
    "arguments": {
      "version": "17.0.19"
    }
  }
}

> {%
    client.global.set("docGenerationTaskId", response.body.result);
    client.log("Doc Generation Task ID: " + client.global.get("docGenerationTaskId"));
%}

### Get Doc Generation Progress
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 6,
  "method": "tools/call",
  "params": {
    "name": "getDocGenerationProgress",
    "arguments": {
      "taskId": "{{docGenerationTaskId}}"
    }
  }
}

### Start Ingest — async task
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 7,
  "method": "tools/call",
  "params": {
    "name": "startIngest",
    "arguments": {
      "version": "17.0.19"
    }
  }
}

> {%
    client.global.set("ingestTaskId", response.body.result);
    client.log("Ingest Task ID: " + client.global.get("ingestTaskId"));
%}

### Get Ingest Progress
POST {{serverMCPUrl}}
Accept: {{accept}}
Content-Type: {{contentType}}
Mcp-Session-Id: {{mcpSessionId}}

{
  "jsonrpc": "{{jsonRpcVersion}}",
  "id": 8,
  "method": "tools/call",
  "params": {
    "name": "getIngestProgress",
    "arguments": {
      "taskId": "{{ingestTaskId}}"
    }
  }
}

