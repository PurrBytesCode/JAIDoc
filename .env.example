# AI — ONNX Transformer Model Paths
# Use file: URIs for absolute paths (e.g., file:///C:/Users/.../onnx/model_qint8_avx512_vnni.onnx)
# Relative paths work when the app is started from the project root
AI_TRANSFORMER_ONNX=./onnx/model_qint8_avx512_vnni.onnx
AI_TRANSFORMER_TOKENIZER=./onnx/tokenizer.json

# Database
DB_USERNAME=jaidoc
DB_PASSWORD=
DB_SHOW_SQL=true

# Logging
LOGGING_PATH_DIRECTORY=./logs
LOGGING_MAX_FILE_SIZE=10MB
LOGGING_MAX_HISTORY_DAYS=7

# SpringDoc / API Docs
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

# Actuator
ACTUATOR_HEALTH_SHOW_DETAILS=ALWAYS
ACTUATOR_LOGGERS_ACCESS=READ_ONLY
ACTUATOR_ENV_SHOW_VALUES=NEVER
ACTUATOR_CONFIGPROPS_SHOW_VALUES=NEVER
ACTUATOR_ENDPOINTS_WEB_EXPOSE=*
ACTUATOR_ENDPOINTS_EXPOSE=*
ACTUATOR_INFO_BUILD_ENABLED=true
ACTUATOR_INFO_JAVA_ENABLED=true

# Documentation (Doclet)
JDK_DIST_DOWNLOAD_DIR=./jdk-distributions
DOCLET_WORK_DIR=./jdk-doc-workspace
DOCLET_OUTPUT_DIR=./data
DOCLET_JAR_DIR=./doclet
DOCLET_JAVADOC_HOME=
DOCLET_MODULES=
